# Committed defaults — loaded first by server.js. Override in `.env` (gitignored) for secrets only,
# or copy any key below into `.env` to replace that default (same variable name wins).
#
# Secrets (e.g. OPENAI_API_KEY): keep them **only** in repo-root `.env` locally. That file is gitignored — never
# commit it or push it to GitHub. Leave `OPENAI_API_KEY=` empty in this tracked file.
#
# Server and scripts/hf_aircraft_detect.py read these keys only (no baked-in numeric defaults).
# Run the detector CLI after the same load order: .env.example then .env (see _hydrate_env in Python).

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5
# Max concurrent OpenAI HTTP requests (HF classify + full vision). Queue excess work until a slot frees.
OPENAI_MAX_CONCURRENT=5
# After HF detection: classify each plane via OpenAI (full-resolution image). Set to 0 for stub labels only.
HF_OPENAI_CLASSIFY=1

# Aircraft pipeline (see AIRCRAFT_ANALYSIS_PROVIDER in server.js)
AIRCRAFT_ANALYSIS_PROVIDER=hf

# --- HF aircraft (see scripts/hf_aircraft_detect.py)
HF_AIRCRAFT_QUICK=0

# Shared (quick + full Efficient-YOLO-RS path)
# Detector score threshold (YOLO). Lower → more boxes / higher recall (good if small fighters are missed);
# higher → fewer false positives. Try 0.02–0.03 for dense or tiny aircraft; 0.04–0.06 for cleaner scenes.
HF_AIRCRAFT_CONF=0.04
HF_AIRCRAFT_TILE=1
HF_AIRCRAFT_AUGMENT=0
HF_AIRCRAFT_MAX_BOX_AREA=0.05
HF_QUICK_KEEP_CLASSES=airplane

# Full HF path (HF_AIRCRAFT_QUICK=0)
HF_AIRCRAFT_REPO=iturslab/Efficient-YOLO-RS-Airplane-Detection
HF_AIRCRAFT_WEIGHTS=training/experiment-61/best.pt
HF_AIRCRAFT_IOU=0.48
HF_AIRCRAFT_MAX_DET=500
HF_AIRCRAFT_IMGSZ=native
HF_AIRCRAFT_IMGSZ_MAX=16384
HF_AIRCRAFT_TILE_OVERLAP=0.56
HF_AIRCRAFT_TILE_MERGE_IOU=0.44

# Quick debug path (HF_AIRCRAFT_QUICK=1) — COCO yolov8n; separate sizing / NMS knobs
HF_AIRCRAFT_QUICK_WEIGHTS=yolov8n.pt
HF_AIRCRAFT_QUICK_IMGSZ=1280
HF_AIRCRAFT_QUICK_IMGSZ_MAX=4096
HF_AIRCRAFT_QUICK_TILE_OVERLAP=0.44
HF_AIRCRAFT_QUICK_IOU=0.53
HF_AIRCRAFT_QUICK_MAX_DET=450
HF_AIRCRAFT_QUICK_TILE_MERGE_IOU=0.46

# Parallel images after HF batch detect (each image may await OpenAI classify). Align with OPENAI_MAX_CONCURRENT to use all slots.
IMAGE_ANALYSIS_CONCURRENCY=5

HF_DETECT_TIMEOUT_MS=600000

# --- Optional toggles (uncomment in `.env` to enable; leave commented here for defaults above only)
# HF_DETECT_DEBUG=1
# HF_AIRCRAFT_DISABLE=1
