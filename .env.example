# Copy this file to `.env` in the repo root and set secrets locally.
# `.env` is gitignored — never commit real keys.

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5

# Aircraft detection: `hf` = Efficient-YOLO-RS via scripts/hf_aircraft_detect.py (normalized boxes, aligns with the viewer).
# `openai` = vision API (optional). `scaffold` = deterministic fake planes.
# HF model card: https://huggingface.co/iturslab/Efficient-YOLO-RS-Airplane-Detection
AIRCRAFT_ANALYSIS_PROVIDER=hf
# Quick-and-dirty COCO detector (yolov8n) to verify boxes/pipeline — remove when debugging is done:
# HF_AIRCRAFT_QUICK=1
# HF_AIRCRAFT_REPO=iturslab/Efficient-YOLO-RS-Airplane-Detection
# HF_AIRCRAFT_WEIGHTS=training/experiment-61/best.pt
# Accuracy-first defaults (slow OK — results are cached):
# HF_AIRCRAFT_CONF=0.001
# HF_AIRCRAFT_IOU=0.45
# HF_AIRCRAFT_MAX_DET=500
# HF_AIRCRAFT_IMGSZ=native
# HF_AIRCRAFT_IMGSZ_MAX=16384
# HF_AIRCRAFT_TILE=1
# HF_AIRCRAFT_TILE_OVERLAP=0.40
# HF_AIRCRAFT_AUGMENT=0
# HF_DETECT_DEBUG=1
# HF_AIRCRAFT_DISABLE=1

# Parallel analysis tasks (default 4). Lower to 1 if GPU/RAM spikes during HF inference.
# IMAGE_ANALYSIS_CONCURRENCY=4
